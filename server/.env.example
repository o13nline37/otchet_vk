# Скопируйте этот файл в server/.env и заполните значения.
# Файл .env НЕ коммитится (см. server/.gitignore).

# --- Сервер ---
# Порт, на котором слушает бэкенд.
PORT=3000

# Разрешённые источники (Origin) фронтенда для CORS, через запятую.
# Локальная разработка + прод (GitHub Pages).
CORS_ORIGIN=http://127.0.0.1:8000,http://localhost:8000,https://o13nline37.github.io

# --- Google Sign-In ---
# OAuth Client ID из Google Cloud Console. Это НЕ секрет.
# То же значение, что в js/googleAuth.js на фронтенде.
GOOGLE_CLIENT_ID=374654641527-uob0v52a95oe0ar9sfud3vai861l3r5t.apps.googleusercontent.com

# --- Whitelist доступа (только сотрудники 108 Media) ---
# Разрешённые почтовые домены, через запятую (без @). Пустое значение = домены не проверяются.
# ЗАМЕНИТЕ на реальный рабочий домен 108 Media.
ALLOWED_EMAIL_DOMAINS=your-company-domain.ru
# Дополнительные точечные email в обход домена, через запятую. Можно оставить пустым.
ALLOWED_EMAILS=

# --- Сессия ---
# Секрет для подписи нашего сессионного JWT. Сгенерируйте случайную длинную строку, например:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# Срок жизни сессии (поддерживает форматы zeit/ms: 30d, 12h, ...).
JWT_EXPIRES_IN=30d

# --- База данных (PostgreSQL) ---
# Строка подключения. Для облачного Postgres (Neon/Supabase) обычно требуется SSL.
DATABASE_URL=postgres://user:password@host:5432/otchet_vk
# Если провайдер требует SSL (Neon/Supabase/Heroku) — поставьте require. Для локального Postgres — disable.
DATABASE_SSL=require
